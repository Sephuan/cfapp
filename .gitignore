# =============================================================================
# DO NOT MODIFY THIS FILE.
# 禁止修改本文件。
#
# Release / publish policy is fixed here. Agents and local tools must not edit
# this file. If a change is truly required, the human owner does it explicitly
# (chmod +w → edit → chmod -w) — never silent drive-by edits.
# =============================================================================

# Everything that starts with a dot (AI tools, caches, editor dirs, env, …).
# Re-include only what must be versioned.
.*
!.gitignore
# Uncomment if you add GitHub Actions / issue templates:
# !.github/

# dependencies
node_modules

# build / packaging output
out
dist
dist-web
*.tgz
*.AppImage
*.deb
*.rpm
*.dmg
*.exe
*.msi

# local standalone / packaged binaries (not the electron/ or src/ tree)
/cfapp

# logs & coverage
logs
*.log
coverage
*.lcov
*.tsbuildinfo

# OS / editor junk (non-dot)
Thumbs.db
*.swp
*~

# agent instruction dumps (not release surface)
CLAUDE.md
AGENTS.md

# personal bootstrap — real CF/AI secrets
scripts/seed-config.ts

# stray local artifacts
/cftui
/debug.ts
